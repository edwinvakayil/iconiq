  },
  "homepage": "https://iconiqui.com",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "prebuild": "node scripts/download-fonts.js",
    "build": "next build",
    "start": "next start",
    "lint": "npx ultracite fix",
    "lint:check": "npx ultracite check",
    "build-registry": "tsx scripts/registry-build.ts",
    "gen-cli": "pnpm run build-registry && pnpm lint",
    "skills:install": "npx skills add https://iconiqui.com --skill iconiq -y",
    "skills:install:local": "npx skills add . --skill iconiq -y"
  },
